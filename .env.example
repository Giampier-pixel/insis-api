# ============================================================
# INSIS API — Variables de entorno
# ============================================================
#
# Este archivo tiene DOS secciones:
#
#   [A] DESARROLLO LOCAL (docker-compose)
#       → Copia este archivo a `.env` y deja activos los valores
#         de la sección [A]. Comenta los de la sección [B].
#         DJANGO_SETTINGS_MODULE = config.settings.local
#
#   [B] PRODUCCIÓN CLOUD RUN
#       → NO se usa este archivo en Cloud Run. Las variables se
#         inyectan vía `--set-env-vars` y los SECRETOS vía
#         `--set-secrets` (Secret Manager) en cloudbuild.yaml.
#         Esta sección queda como REFERENCIA documental de qué
#         variables debe tener configuradas el servicio.
#         DJANGO_SETTINGS_MODULE = config.settings.production
#
# Regla: NUNCA subir un `.env` real al repositorio.
#        Solo este `.env.example` con valores ficticios.
# ============================================================


# ============================================================
# [A] DESARROLLO LOCAL — docker-compose up
# ============================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=dev-secret-key-cambiame-en-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- MySQL local (servicio "db" del docker-compose) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=insis_db
DB_USER=insis_user
DB_PASSWORD=insis_dev_password
DB_ROOT_PASSWORD=root_dev_password

# --- Celery / Redis local (servicio "redis" del docker-compose) ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Email en local: backend de consola ---
# Imprime los emails en stdout del contenedor web.
# No se envía nada por SMTP de verdad.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=INSIS Local <noreply@insis.local>

# --- Storage local ---
# En local los archivos viven en MEDIA_ROOT del contenedor.
# No se usa GCS.
USE_GCS=False

# --- CORS local (frontend en localhost) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000


# ============================================================
# [B] PRODUCCIÓN CLOUD RUN — referencia documental
# ============================================================
# Estas variables NO se cargan desde este archivo en producción.
# Se configuran en cloudbuild.yaml con:
#   --set-env-vars=KEY=VALUE,...
#   --set-secrets=KEY=secret-name:latest,...
#
# Lo que aquí aparece es LA LISTA de variables que el servicio
# Cloud Run debe tener inyectadas.
# ============================================================

# --- Django (env-vars en Cloud Run) ---
# DJANGO_SETTINGS_MODULE=config.settings.production
# DEBUG=False
# ALLOWED_HOSTS=insis-api-xxxxxx-uc.a.run.app,api.insis.com

# --- Cloud SQL (env-vars en Cloud Run) ---
# Usa Cloud SQL Auth Proxy vía socket Unix:
# DB_HOST=/cloudsql/PROJECT_ID:us-central1:insis-mysql
# DB_PORT=3306
# DB_NAME=insis_db
# DB_USER=insis_app
# DB_PASSWORD=  ← inyectado vía --set-secrets=DB_PASSWORD=db-password:latest

# --- Redis (Memorystore) — env-vars ---
# CELERY_BROKER_URL=redis://10.x.x.x:6379/0
# CELERY_RESULT_BACKEND=redis://10.x.x.x:6379/0
# (El IP privado del Memorystore se obtiene tras provisionarlo;
#  Cloud Run accede vía VPC Connector.)

# --- Email producción (SMTP real) — secret en Cloud Run ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=noreply@insis.com
# EMAIL_HOST_PASSWORD=  ← inyectado vía --set-secrets=EMAIL_HOST_PASSWORD=smtp-password:latest
# DEFAULT_FROM_EMAIL=INSIS <noreply@insis.com>

# --- Storage GCS (env-vars + secret de service account) ---
# USE_GCS=True
# GCS_BUCKET_NAME=insis-reports
# GCS_PROJECT_ID=tu-proyecto-gcp
# (Cloud Run usa la Service Account asociada al servicio,
#  no se monta JSON de credenciales.)

# --- Secret Manager (referencia de los nombres de secretos) ---
# - django-secret           → SECRET_KEY de Django
# - db-password             → password del usuario insis_app
# - smtp-password           → password de la cuenta de envío de emails
# - (futuro) stripe-key     → cuando se integre pagos

# --- CORS producción (env-var) ---
# CORS_ALLOWED_ORIGINS=https://app.insis.com,https://admin.insis.com

# --- Reportes asíncronos (env-vars) ---
# REPORT_EXPORT_BUCKET=insis-reports
# REPORT_SIGNED_URL_TTL_SECONDS=1800
