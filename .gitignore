# ============================================================
# INSIS API — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl

# --- Virtual environment ---
venv/
.venv/
env/
ENV/

# --- Django ---
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
static_collected/
media/
*.pot
*.mo

# --- Environment ---
.env
.env.*
!.env.example

# --- Git worktrees ---
.worktrees/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- Docker ---
docker-compose.override.yml

# --- Coverage ---
htmlcov/
.coverage
.coverage.*
coverage.xml

# --- pytest ---
.pytest_cache/

# --- mypy ---
.mypy_cache/

# --- OS ---
.DS_Store
Thumbs.db

# --- Celery ---
celerybeat-schedule
celerybeat.pid
